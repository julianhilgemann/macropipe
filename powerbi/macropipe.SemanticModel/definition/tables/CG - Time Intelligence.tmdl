/// Centralized time-intelligence calculation group applied to any base measure.
/// Provides Current, MTD/QTD/YTD, Prior Year equivalents, Rolling 12M,
/// MoM/YoY absolute and percentage variances.
/// Reduces measure duplication and ensures consistent date-shift logic.
///
table 'CG - Time Intelligence'
	lineageTag: a1b2c3d4-0004-4000-a000-000000000001

	calculationGroup
		precedence: 1

		calculationItem Current = SELECTEDMEASURE()

		calculationItem MTD =
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESMTD(synth_dim_date[Date])
				)

		calculationItem QTD =
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESQTD(synth_dim_date[Date])
				)

		calculationItem YTD =
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESYTD(synth_dim_date[Date])
				)

		calculationItem PY =
				CALCULATE(
				    SELECTEDMEASURE(),
				    SAMEPERIODLASTYEAR(synth_dim_date[Date])
				)

		calculationItem 'PY MTD' =
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESMTD(synth_dim_date[Date]),
				    SAMEPERIODLASTYEAR(synth_dim_date[Date])
				)

		calculationItem 'PY QTD' =
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESQTD(synth_dim_date[Date]),
				    SAMEPERIODLASTYEAR(synth_dim_date[Date])
				)

		calculationItem 'PY YTD' =
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESYTD(synth_dim_date[Date]),
				    SAMEPERIODLASTYEAR(synth_dim_date[Date])
				)

		calculationItem 'Δ YoY' =
				VAR _Current = SELECTEDMEASURE()
				VAR _PY = CALCULATE(
				    SELECTEDMEASURE(),
				    SAMEPERIODLASTYEAR(synth_dim_date[Date])
				)
				RETURN
				IF(NOT ISBLANK(_PY), _Current - _PY, BLANK())

		calculationItem 'Δ% YoY' =
				VAR _Current = SELECTEDMEASURE()
				VAR _PY = CALCULATE(
				    SELECTEDMEASURE(),
				    SAMEPERIODLASTYEAR(synth_dim_date[Date])
				)
				RETURN
				IF(NOT ISBLANK(_PY), DIVIDE(_Current - _PY, _PY, 0), BLANK())

			formatStringDefinition = "+0.0%;-0.0%;0.0%"

		calculationItem 'Δ% YoY MTD' =
				VAR _Current = CALCULATE(
				    SELECTEDMEASURE(),
				    DATESMTD(synth_dim_date[Date])
				)
				VAR _PY = CALCULATE(
				    SELECTEDMEASURE(),
				    DATESMTD(synth_dim_date[Date]),
				    SAMEPERIODLASTYEAR(synth_dim_date[Date])
				)
				RETURN
				IF(NOT ISBLANK(_PY), DIVIDE(_Current - _PY, _PY, 0), BLANK())

			formatStringDefinition = "+0.0%;-0.0%;0.0%"

		calculationItem 'Δ% YoY QTD' =
				VAR _Current = CALCULATE(
				    SELECTEDMEASURE(),
				    DATESQTD(synth_dim_date[Date])
				)
				VAR _PY = CALCULATE(
				    SELECTEDMEASURE(),
				    DATESQTD(synth_dim_date[Date]),
				    SAMEPERIODLASTYEAR(synth_dim_date[Date])
				)
				RETURN
				IF(NOT ISBLANK(_PY), DIVIDE(_Current - _PY, _PY, 0), BLANK())

			formatStringDefinition = "+0.0%;-0.0%;0.0%"

		calculationItem 'Δ% YoY YTD' =
				VAR _Current = CALCULATE(
				    SELECTEDMEASURE(),
				    DATESYTD(synth_dim_date[Date])
				)
				VAR _PY = CALCULATE(
				    SELECTEDMEASURE(),
				    DATESYTD(synth_dim_date[Date]),
				    SAMEPERIODLASTYEAR(synth_dim_date[Date])
				)
				RETURN
				IF(NOT ISBLANK(_PY), DIVIDE(_Current - _PY, _PY, 0), BLANK())

			formatStringDefinition = "+0.0%;-0.0%;0.0%"

		calculationItem 'MoM (Prior Month)' =
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATEADD(synth_dim_date[Date], -1, MONTH)
				)

		calculationItem 'Δ% MoM' =
				VAR _Current = SELECTEDMEASURE()
				VAR _PM = CALCULATE(
				    SELECTEDMEASURE(),
				    DATEADD(synth_dim_date[Date], -1, MONTH)
				)
				RETURN
				IF(NOT ISBLANK(_PM), DIVIDE(_Current - _PM, _PM, 0), BLANK())

			formatStringDefinition = "+0.0%;-0.0%;0.0%"

		calculationItem 'Rolling 12 Months' =
				CALCULATE(
				    SELECTEDMEASURE(),
				    DATESINPERIOD(
				        synth_dim_date[Date],
				        MAX(synth_dim_date[Date]),
				        -12,
				        MONTH
				    )
				)

	column 'Time Calculation'
		dataType: string
		lineageTag: a1b2c3d4-0004-4000-a000-000000000011
		summarizeBy: none
		sourceColumn: Name
		sortByColumn: Ordinal

		annotation SummarizationSetBy = Automatic

	column Ordinal
		dataType: int64
		formatString: 0
		lineageTag: a1b2c3d4-0004-4000-a000-000000000012
		summarizeBy: sum
		sourceColumn: Ordinal
		isHidden

		annotation SummarizationSetBy = Automatic
