{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visual/3.3.0/schema.json",
  "name": "line_fct_vs_last_act",
  "visual": {
    "visualType": "lineChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": { "SourceRef": { "Entity": "synth_dim_date" } },
                  "Property": "Year Month"
                }
              },
              "queryRef": "synth_dim_date.Year Month"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": { "SourceRef": { "Entity": "_Measures" } },
                  "Property": "Value ACT|FCT"
                }
              },
              "queryRef": "_Measures.Value ACT|FCT"
            },
            {
              "field": {
                "Measure": {
                  "Expression": { "SourceRef": { "Entity": "_Measures" } },
                  "Property": "CI Upper 90"
                }
              },
              "queryRef": "_Measures.CI Upper 90"
            },
            {
              "field": {
                "Measure": {
                  "Expression": { "SourceRef": { "Entity": "_Measures" } },
                  "Property": "CI Lower 90"
                }
              },
              "queryRef": "_Measures.CI Lower 90"
            }
          ]
        },
        "Series": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": { "SourceRef": { "Entity": "fct_macro_series" } },
                  "Property": "series_name"
                }
              },
              "queryRef": "fct_macro_series.series_name"
            }
          ]
        }
      },
      "filters": [
        {
          "name": "filter_hl_vol_all",
          "expression": {
            "Column": {
              "Expression": { "SourceRef": { "Entity": "fct_macro_series" } },
              "Property": "series_name"
            }
          },
          "filter": {
            "Where": [
              {
                "Condition": {
                  "In": {
                    "Expressions": [
                      {
                        "Column": {
                          "Expression": { "SourceRef": { "Entity": "fct_macro_series" } },
                          "Property": "series_name"
                        }
                      }
                    ],
                    "Values": [
                      [{ "Literal": { "Value": "'HL_Vol_Float'" } }],
                      [{ "Literal": { "Value": "'HL_Vol_1_5Y'" } }],
                      [{ "Literal": { "Value": "'HL_Vol_5_10Y'" } }],
                      [{ "Literal": { "Value": "'HL_Vol_10Y'" } }],
                      [{ "Literal": { "Value": "'HL_Vol_Total'" } }]
                    ]
                  }
                }
              }
            ]
          },
          "type": "Advanced"
        }
      ]
    },
    "title": "All HL Volume Series — ACT + Forecast w/ 90% CI"
  },
  "position": { "x": 20, "y": 360, "width": 1240, "height": 340, "z": 2 }
}