{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visual/3.3.0/schema.json",
  "name": "line_hl_aprc",
  "visual": {
    "visualType": "lineChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": { "SourceRef": { "Entity": "synth_dim_date" } },
                  "Property": "Year Month"
                }
              },
              "queryRef": "synth_dim_date.Year Month"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": { "SourceRef": { "Entity": "_Measures" } },
                  "Property": "Value ACT"
                }
              },
              "queryRef": "_Measures.Value ACT"
            }
          ]
        },
        "Series": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": { "SourceRef": { "Entity": "fct_macro_series" } },
                  "Property": "series_name"
                }
              },
              "queryRef": "fct_macro_series.series_name"
            }
          ]
        }
      },
      "filters": [
        {
          "name": "filter_hl_rates",
          "expression": {
            "Column": {
              "Expression": { "SourceRef": { "Entity": "fct_macro_series" } },
              "Property": "series_name"
            }
          },
          "filter": {
            "Where": [
              {
                "Condition": {
                  "In": {
                    "Expressions": [
                      {
                        "Column": {
                          "Expression": { "SourceRef": { "Entity": "fct_macro_series" } },
                          "Property": "series_name"
                        }
                      }
                    ],
                    "Values": [
                      [{ "Literal": { "Value": "'HL_Rate_Total'" } }],
                      [{ "Literal": { "Value": "'HL_Rate_Float'" } }],
                      [{ "Literal": { "Value": "'HL_Rate_1_5Y'" } }],
                      [{ "Literal": { "Value": "'HL_Rate_5_10Y'" } }],
                      [{ "Literal": { "Value": "'HL_Rate_10Y'" } }]
                    ]
                  }
                }
              }
            ]
          },
          "type": "Advanced"
        }
      ]
    },
    "title": "Housing Loan Rates by Maturity (APRC Total + Buckets)"
  },
  "position": { "x": 20, "y": 410, "width": 620, "height": 290, "z": 7 }
}